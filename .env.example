ENV=development
PORT=8080

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=ratelimiter
DB_SSLMODE=disable

# Redis Settings
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=

KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=api_logs
KAFKA_GROUP_ID=analytics_consumers
KAFKA_DLQ_TOPIC=api_logs_dlq

# OpenTelemetry
OTEL_ENDPOINT=localhost:4317

JWT_SECRET=super_secret_jwt_key_please_change_in_production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

ADMIN_EMAIL=admin@ratelimiter.io
ADMIN_PASSWORD=AdminPass123!

# Lemon Squeezy billing
LEMON_SQUEEZY_WEBHOOK_SECRET=
LEMON_SQUEEZY_PRO_VARIANT_ID=1899978

# Email (Resend) — password reset links. Leave RESEND_API_KEY empty to log emails in dev.
RESEND_API_KEY=
RESEND_FROM=Limiter.io <onboarding@resend.dev>
APP_BASE_URL=http://localhost:3000

# CORS: "*" for any origin (dev), or a comma-separated allowlist for production
# e.g. CORS_ALLOWED_ORIGINS=https://app.limiter.io,https://limiter.io
CORS_ALLOWED_ORIGINS=*
