# Copy to .env.local and adjust for your environment.
# Base URL of the Go API server (defaults to http://localhost:8080/api/v1 if unset).
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# Lemon Squeezy hosted checkout link for the Pro plan (from your LS dashboard).
NEXT_PUBLIC_LEMONSQUEEZY_CHECKOUT_URL=

# Enterprise / sales contact address shown on the pricing page.
NEXT_PUBLIC_SALES_EMAIL=sales@limiter.io
